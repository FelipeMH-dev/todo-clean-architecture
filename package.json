  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "yarn migration:run && nest start --watch",
    "start:prod": "yarn migration:run && node dist/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:run": "ts-node src/scripts/run-migrations.ts",
    "migration:show": "typeorm migration:show -d dist/infrastructure/database/typeorm-cli.datasource.js",
    "migration:revert": "typeorm migration:revert -d dist/infrastructure/database/typeorm-cli.datasource.js"
  },
